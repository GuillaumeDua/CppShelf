{
  "version": 3,
  "configurePresets": [
    {
      "name": "clang-libstdcxx-dev",
      "displayName": "Clang + libstdc++ (all components)",
      "inherits": "clang-libstdcxx",
      "cacheVariables": {
        "CSL_BUILD_ALL":   { "type": "BOOL", "value": "ON" },
        "CSL_TEST_ALL":    { "type": "BOOL", "value": "ON" },
        "CSL_EXAMPLE_ALL": { "type": "BOOL", "value": "ON" }
      }
    },
    {
      "name": "clang-libcxx-dev",
      "displayName": "Clang + libc++ (all components)",
      "inherits": "clang-libcxx",
      "cacheVariables": {
        "CSL_BUILD_ALL":   { "type": "BOOL", "value": "ON" },
        "CSL_TEST_ALL":    { "type": "BOOL", "value": "ON" },
        "CSL_EXAMPLE_ALL": { "type": "BOOL", "value": "ON" }
      }
    },
    {
      "name": "gcc-dev",
      "displayName": "GCC + libstdc++ (all components)",
      "inherits": "gcc",
      "cacheVariables": {
        "CSL_BUILD_ALL":   { "type": "BOOL", "value": "ON" },
        "CSL_TEST_ALL":    { "type": "BOOL", "value": "ON" },
        "CSL_EXAMPLE_ALL": { "type": "BOOL", "value": "ON" }
      }
    }
  ],
  "buildPresets": [
    { "name": "base-build-dev", "hidden": true },
    { "name": "clang-libstdcxx-dev-debug",   "inherits": "base-build-dev", "configurePreset": "clang-libstdcxx-dev", "configuration": "Debug"   },
    { "name": "clang-libstdcxx-dev-release", "inherits": "base-build-dev", "configurePreset": "clang-libstdcxx-dev", "configuration": "Release" },
    { "name": "clang-libcxx-dev-debug",      "inherits": "base-build-dev", "configurePreset": "clang-libcxx-dev",    "configuration": "Debug"   },
    { "name": "clang-libcxx-dev-release",    "inherits": "base-build-dev", "configurePreset": "clang-libcxx-dev",    "configuration": "Release" },
    { "name": "gcc-dev-debug",               "inherits": "base-build-dev", "configurePreset": "gcc-dev",             "configuration": "Debug"   },
    { "name": "gcc-dev-release",             "inherits": "base-build-dev", "configurePreset": "gcc-dev",             "configuration": "Release" }
  ],
  "testPresets": [
    {
      "name": "base-test-dev",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 10 }
    },
    { "name": "clang-libstdcxx-dev-debug",   "inherits": "base-test-dev", "configurePreset": "clang-libstdcxx-dev", "configuration": "Debug"   },
    { "name": "clang-libstdcxx-dev-release", "inherits": "base-test-dev", "configurePreset": "clang-libstdcxx-dev", "configuration": "Release" },
    { "name": "clang-libcxx-dev-debug",      "inherits": "base-test-dev", "configurePreset": "clang-libcxx-dev",    "configuration": "Debug"   },
    { "name": "clang-libcxx-dev-release",    "inherits": "base-test-dev", "configurePreset": "clang-libcxx-dev",    "configuration": "Release" },
    { "name": "gcc-dev-debug",               "inherits": "base-test-dev", "configurePreset": "gcc-dev",             "configuration": "Debug"   },
    { "name": "gcc-dev-release",             "inherits": "base-test-dev", "configurePreset": "gcc-dev",             "configuration": "Release" }
  ]
}
